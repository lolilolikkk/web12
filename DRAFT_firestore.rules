rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Check if user is Master (using a specific UID or email if we had one)
    // For now, let's assume we use a master UID from config if available, 
    // or just allow authenticated users for master actions if they are the designated master.
    // Since we don't know the master UID yet, I'll use a placeholder or check against a collection.
    function isMaster() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /inventory/{productId} {
      allow read: if true; // Everyone can browse products
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'image', 'category'])
      );
      allow delete: if isSignedIn();
    }

    match /orders/{orderId} {
      // Order list must be filtered by phone in the query
      allow list: if isSignedIn() && (isMaster() || resource.data.phone == request.auth.token.phone_number);
      allow get: if isSignedIn() && (isMaster() || resource.data.phone == request.auth.token.phone_number);
      allow create: if isValidOrder(incoming());
      allow update: if isMaster() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'masterMessage'])
      );
      allow delete: if isMaster();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'shopId'])
          && data.name is string && data.name.size() <= 100
          && data.price is number && data.price >= 0
          && data.image is string && data.image.size() <= 2000000 // 2MB base64
          && data.shopId is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['productName', 'price', 'shopName', 'phone', 'status'])
          && data.productName is string
          && data.price is number
          && data.shopName is string
          && data.phone is string
          && data.status in ['pending', 'Accepted', 'Refused'];
    }
  }
}
