rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PUBLIC ACCESS FOR TESTING (Permissive for 30 days)
    // IMPORTANT: Enable Anonymous Auth in Firebase Console for better security!
    match /inventory/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /shop_settings/{settingId} {
      allow read, write: if true;
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
